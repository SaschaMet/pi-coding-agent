{
    "name": "pi-coding-agent",
    "version": "1.0.0",
    "description": "Project-local PI coding agent parity stack",
    "main": "src/main.ts",
    "scripts": {
        "dev": "tsx watch src/main.ts --container --no-container-net --no-container-mount-skills --container-image thegreataxios/pi-sandbox@sha256:be6d992940f63e435ba5cdd840a9b26003f0694fb36b749a4ddf121555d79d9e",
        "agent": "tsx src/main.ts --container --no-container-net --no-container-mount-skills --container-image thegreataxios/pi-sandbox@sha256:be6d992940f63e435ba5cdd840a9b26003f0694fb36b749a4ddf121555d79d9e",
        "smoke": "tsx scripts/smoke.ts",
        "typecheck": "tsc --noEmit",
        "test": "vitest run",
        "test:coverage": "vitest run --coverage",
        "pi:pull-global": "tsx scripts/sync-pi-config.ts pull",
        "pi:sync-global": "tsx scripts/sync-pi-config.ts push"
    },
    "keywords": [],
    "author": "",
    "license": "ISC",
    "type": "module",
    "dependencies": {
        "@mariozechner/pi-agent-core": "^0.65.0",
        "@mariozechner/pi-ai": "^0.65.0",
        "@mariozechner/pi-coding-agent": "^0.65.0",
        "@mariozechner/pi-tui": "^0.65.0",
        "@sinclair/typebox": "^0.34.49",
        "chalk": "^5.6.2"
    },
    "devDependencies": {
        "@types/node": "^25.5.2",
        "@vitest/coverage-v8": "^4.1.2",
        "tsx": "^4.21.0",
        "typescript": "^6.0.2",
        "vitest": "^4.1.2"
    }
}
