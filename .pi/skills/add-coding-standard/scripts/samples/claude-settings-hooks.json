{
  "hooks": {
    "PreToolUse": [
      {
        "matcher": ".*",
        "hooks": [
          {
            "type": "command",
            "command": "node .github/hooks/quality-guard.mjs",
            "timeout": 20
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": ".*",
        "hooks": [
          {
            "type": "command",
            "command": "node .github/hooks/quality-guard.mjs",
            "timeout": 300
          }
        ]
      }
    ]
  }
}
