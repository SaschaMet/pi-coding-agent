{
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": ".github/hooks/scripts/block-env-read.sh",
            "timeout": 20
          }
        ]
      },
      {
        "matcher": "Read|Grep|LS|Glob|Edit|Write|MultiEdit",
        "hooks": [
          {
            "type": "command",
            "command": ".github/hooks/scripts/block-env-read.sh",
            "timeout": 20
          }
        ]
      }
    ],
    "Stop": [
      {
        "matcher": ".*",
        "hooks": [
          {
            "type": "command",
            "command": ".github/hooks/scripts/lint-on-session-end.sh",
            "timeout": 300
          }
        ]
      }
    ]
  }
}
