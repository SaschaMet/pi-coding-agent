{
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "${PLUGIN_ROOT}/hooks/block-env-read.sh",
            "timeout": 20,
            "statusMessage": "Checking .env guard"
          }
        ]
      },
      {
        "matcher": "Read|Grep|LS|Glob|Edit|Write|MultiEdit",
        "hooks": [
          {
            "type": "command",
            "command": "${PLUGIN_ROOT}/hooks/block-env-read.sh",
            "timeout": 20,
            "statusMessage": "Checking .env guard"
          }
        ]
      }
    ],
    "Stop": [
      {
        "matcher": ".*",
        "hooks": [
          {
            "type": "command",
            "command": "${PLUGIN_ROOT}/hooks/lint-on-session-end.sh",
            "timeout": 300,
            "statusMessage": "Running session-end lint"
          }
        ]
      }
    ]
  }
}
