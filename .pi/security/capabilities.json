{
    "version": 1,
    "defaultAction": "deny",
    "protectedPathSegments": [],
    "protectedBasenames": [
        ".env"
    ],
    "protectedBasenamePrefixes": [
        ".env."
    ],
    "tools": {
        "bash": {
            "mode": "allow",
            "nonInteractivePolicy": "deny",
            "bashPolicy": {
                "defaultAction": "allow",
                "nonInteractiveConfirm": "deny",
                "rules": [
                    {
                        "pattern": "(^|\\s)(cat|head|tail|less|more|grep|rg|awk|sed)\\b[^\\n]*\\s(\\./)?\\.env(\\.[\\w.-]+)?(\\s|$)",
                        "action": "confirm",
                        "reason": "Reading .env files requires confirmation"
                    },
                    {
                        "pattern": "\\b(rm|rmdir|unlink|del|erase)\\b|\\bgit\\s+(rm|branch\\s+-[dD])\\b",
                        "action": "confirm",
                        "reason": "Delete/remove command requires confirmation"
                    },
                    {
                        "pattern": "^\\s*ls\\b",
                        "action": "allow"
                    },
                    {
                        "pattern": "^\\s*pwd\\b",
                        "action": "allow"
                    },
                    {
                        "pattern": "^\\s*cat\\b",
                        "action": "allow"
                    },
                    {
                        "pattern": "^\\s*head\\b",
                        "action": "allow"
                    },
                    {
                        "pattern": "^\\s*tail\\b",
                        "action": "allow"
                    },
                    {
                        "pattern": "^\\s*more\\b",
                        "action": "allow"
                    },
                    {
                        "pattern": "^\\s*less\\b",
                        "action": "allow"
                    },
                    {
                        "pattern": "^\\s*grep\\b",
                        "action": "allow"
                    },
                    {
                        "pattern": "^\\s*rg\\b",
                        "action": "allow"
                    },
                    {
                        "pattern": "^\\s*jq\\b",
                        "action": "allow"
                    },
                    {
                        "pattern": "^\\s*find\\b",
                        "action": "allow"
                    },
                    {
                        "pattern": "^\\s*fd\\b",
                        "action": "allow"
                    },
                    {
                        "pattern": "^\\s*wc\\b",
                        "action": "allow"
                    },
                    {
                        "pattern": "^\\s*sort\\b",
                        "action": "allow"
                    },
                    {
                        "pattern": "^\\s*uniq\\b",
                        "action": "allow"
                    },
                    {
                        "pattern": "^\\s*diff\\b",
                        "action": "allow"
                    },
                    {
                        "pattern": "^\\s*file\\b",
                        "action": "allow"
                    },
                    {
                        "pattern": "^\\s*stat\\b",
                        "action": "allow"
                    },
                    {
                        "pattern": "^\\s*du\\b",
                        "action": "allow"
                    },
                    {
                        "pattern": "^\\s*df\\b",
                        "action": "allow"
                    },
                    {
                        "pattern": "^\\s*tree\\b",
                        "action": "allow"
                    },
                    {
                        "pattern": "^\\s*(echo|printf)\\b",
                        "action": "allow"
                    },
                    {
                        "pattern": "^\\s*(which|whereis|type)\\b",
                        "action": "allow"
                    },
                    {
                        "pattern": "^\\s*(uname|whoami|id|date|cal|uptime|ps|top|htop|free)\\b",
                        "action": "allow"
                    },
                    {
                        "pattern": "^\\s*git\\s+(status|log|diff|show|branch|remote|config\\s+--get)\\b",
                        "action": "allow"
                    },
                    {
                        "pattern": "^\\s*git\\s+ls-",
                        "action": "allow"
                    },
                    {
                        "pattern": "^\\s*npm\\s+(test|run\\s+(test|smoke|typecheck|test:coverage|docs:sync-pi)|list|ls|view|info|search|outdated|audit)\\b",
                        "action": "allow"
                    },
                    {
                        "pattern": "^\\s*npm\\b",
                        "action": "allow"
                    },
                    {
                        "pattern": "^\\s*yarn\\s+(test|list|info|why|audit)\\b",
                        "action": "allow"
                    },
                    {
                        "pattern": "^\\s*yarn\\b",
                        "action": "allow"
                    },
                    {
                        "pattern": "^\\s*pnpm\\s+(test|list|info|why|audit)\\b",
                        "action": "allow"
                    },
                    {
                        "pattern": "^\\s*pnpm\\b",
                        "action": "allow"
                    },
                    {
                        "pattern": "^\\s*npx\\b",
                        "action": "allow"
                    },
                    {
                        "pattern": "^\\s*bunx?\\b",
                        "action": "allow"
                    },
                    {
                        "pattern": "^\\s*pnpm\\s+(-s\\s+)?tsc\\b(?=.*\\s--noEmit\\b)",
                        "action": "allow"
                    },
                    {
                        "pattern": "^\\s*node\\s+--version\\b",
                        "action": "allow"
                    },
                    {
                        "pattern": "^\\s*python\\s+--version\\b",
                        "action": "allow"
                    },
                    {
                        "pattern": "^\\s*php\\b",
                        "action": "allow"
                    },
                    {
                        "pattern": "^\\s*composer\\b",
                        "action": "allow"
                    },
                    {
                        "pattern": "^\\s*python3?\\b",
                        "action": "allow"
                    },
                    {
                        "pattern": "^\\s*python3\\s+(-V|--version)\\b",
                        "action": "allow"
                    },
                    {
                        "pattern": "^\\s*uv\\s+(-V|--version)\\b",
                        "action": "allow"
                    },
                    {
                        "pattern": "^\\s*uv\\s+run\\b",
                        "action": "allow"
                    },
                    {
                        "pattern": "^\\s*uv\\s+run\\s+--python\\s+3\\.12\\s+python3?\\s+(-V|--version)\\b",
                        "action": "allow"
                    }
                ],
                "sensitivePatterns": [],
                "networkDenyCommands": [],
                "networkAllowPatterns": [],
                "envAllowlist": [
                    "PATH",
                    "HOME",
                    "SHELL",
                    "PWD",
                    "TMPDIR",
                    "TMP",
                    "TEMP",
                    "LANG",
                    "LC_ALL",
                    "LC_CTYPE",
                    "TERM",
                    "COLORTERM",
                    "NO_COLOR",
                    "TZ",
                    "USER",
                    "LOGNAME",
                    "EDITOR"
                ]
            }
        },
        "read": {
            "mode": "allow",
            "pathPolicy": {
                "denyProtectedPaths": true
            }
        },
        "write": {
            "mode": "allow"
        },
        "edit": {
            "mode": "allow"
        },
        "ls": {
            "mode": "allow"
        },
        "grep": {
            "mode": "allow"
        },
        "find": {
            "mode": "allow"
        },
        "ask_questions": {
            "mode": "allow"
        },
        "ask": {
            "mode": "allow"
        },
        "web_search": {
            "mode": "allow"
        },
        "fetch_web_page": {
            "mode": "allow"
        },
        "subagent": {
            "mode": "allow"
        }
    }
}
